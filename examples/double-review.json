      "id": "codex",
      "adapter": "codex-cli",
      "timeoutMs": 600000
    },
    {
      "id": "glm-5.2",
      "adapter": "little-coder-model",
      "model": "ollama/glm-5.2",
      "timeoutMs": 600000
    }
  ]
}
