{
  "enabled": true,
  "mode": "quorum",
  "maxCorrectionCycles": 1,
  "reviewWhen": "changed-files",
  "maxPatchBytes": 200000,
  "maxFileBytes": 1048576,
  "maxSnapshotBytes": 52428800,
  "retainBundles": "on-failure",
  "reviewers": [
    {
      "id": "claude",
      "adapter": "claude-cli",
      "timeoutMs": 300000
    }
  ],
  "decider": {
    "id": "claude-decider",
    "adapter": "claude-cli",
    "timeoutMs": 300000
  }
}
